<%- include('partials/header') %>

    <section class="error-section">
        <div class="container" style="text-align: center; padding: 100px 20px;">
            <div style="font-size: 6rem; margin-bottom: 10px;">⚠️</div>
            <h1 style="font-size: 3rem; color: #e74c3c; margin-bottom: 10px;">Oops!</h1>
            <h2 style="margin-bottom: 10px; color: var(--text, #333);">
                <%= message || 'Something went wrong!' %>
            </h2>
            <p
                style="color: var(--text-light, #666); margin-bottom: 30px; max-width: 500px; margin-left: auto; margin-right: auto;">
                An unexpected error occurred. Please try again later.
            </p>
            <a href="/" class="btn btn-primary">Back to Home</a>
        </div>
    </section>

    <%- include('partials/footer') %>