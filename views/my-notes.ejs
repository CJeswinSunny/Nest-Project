<%- include('partials/header') %>

    <section style="padding: 60px 0;">
        <div class="container">
            <div
                style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px; border-bottom: 1px solid var(--border-color); padding-bottom: 20px;">
                <div>
                    <h1 style="font-size: 2.5rem; margin-bottom: 10px;">My Uploads</h1>
                    <p style="color: var(--text-muted); font-size: 1.1rem;">Manage the study materials you've shared
                        with others.</p>
                </div>
                <div style="text-align: right;">
                    <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 5px;">Total Downloads</p>
                    <div style="font-size: 2rem; font-weight: 800; color: var(--primary);">
                        <%= totalDownloads %>
                    </div>
                </div>
            </div>

            <% if (notes.length===0) { %>
                <div class="empty-state">
                    <div class="empty-icon">📁</div>
                    <h2>You haven't uploaded any notes yet</h2>
                    <p>Start sharing your knowledge to help your fellow students and build your profile.</p>
                    <a href="/notes/upload" class="btn btn-primary btn-lg" style="margin-top: 15px;">Upload Your First
                        Note</a>
                </div>
                <% } else { %>
                    <div class="notes-grid">
                        <% notes.forEach(function(note) { %>
                            <div class="note-card" style="padding-bottom: 70px;">
                                <div class="note-card-header">
                                    <span class="note-subject-badge">
                                        <%= note.subject %>
                                    </span>
                                    <span class="note-file-type">
                                        <%= note.original_name.split('.').pop().toUpperCase() %>
                                    </span>
                                </div>
                                <h3 class="note-title">
                                    <%= note.title %>
                                </h3>
                                <% if (note.description) { %>
                                    <p class="note-desc">
                                        <%= note.description.substring(0, 100) %>
                                            <%= note.description.length> 100 ? '...' : '' %>
                                    </p>
                                    <% } %>
                                        <div class="note-meta" style="margin-bottom: 15px;">
                                            <div class="note-stats-row">
                                                <span class="note-stat">⬇️ <%= note.download_count %> Downloads</span>
                                                <span class="note-stat">💾 <%= (note.file_size / 1024).toFixed(0) %>
                                                        KB</span>
                                            </div>
                                        </div>
                                        <div
                                            style="position: absolute; bottom: 20px; left: 20px; right: 20px; display: flex; gap: 10px;">
                                            <a href="/notes/<%= note.id %>" class="btn"
                                                style="flex: 1; background: rgba(255,255,255,0.1); color: white;">View</a>
                                            <form action="/notes/<%= note.id %>/delete" method="POST" style="flex: 1;"
                                                onsubmit="return confirm('Are you sure you want to delete this note?');">
                                                <button type="submit" class="btn"
                                                    style="width: 100%; background: rgba(239, 68, 68, 0.2); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3);">Delete</button>
                                            </form>
                                        </div>
                            </div>
                            <% }); %>
                    </div>
                    <% } %>
        </div>
    </section>

    <%- include('partials/footer') %>