<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="NoteShare — Share and discover student study notes. Upload PDF, DOC, PPT and more.">
  <title><%= typeof title !== 'undefined' ? title : 'NoteShare' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Navigation -->
  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="nav-brand">
        <span class="brand-icon">📝</span>
        <span class="brand-text">Note<span class="brand-accent">Share</span></span>
      </a>

      <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
        <span></span><span></span><span></span>
      </button>

      <div class="nav-links" id="navLinks">
        <a href="/" class="nav-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Home
        </a>
        <% if (currentUser) { %>
          <a href="/notes/upload" class="nav-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            Upload
          </a>
          <a href="/my-notes" class="nav-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            My Notes
          </a>
          <div class="nav-user">
            <div class="nav-avatar" style="background-color: <%= currentUser.avatar_color %>">
              <%= currentUser.username.charAt(0).toUpperCase() %>
            </div>
            <span class="nav-username"><%= currentUser.username %></span>
            <a href="/logout" class="nav-link nav-logout">Logout</a>
          </div>
        <% } else { %>
          <a href="/login" class="nav-link">Login</a>
          <a href="/register" class="btn btn-primary btn-sm">Sign Up</a>
        <% } %>
      </div>
    </div>
  </nav>

  <!-- Flash Messages -->
  <% if (success) { %>
    <div class="flash flash-success" id="flashMsg">
      <span><%= success %></span>
      <button class="flash-close" onclick="this.parentElement.remove()">×</button>
    </div>
  <% } %>
  <% if (error) { %>
    <div class="flash flash-error" id="flashMsg">
      <span><%= error %></span>
      <button class="flash-close" onclick="this.parentElement.remove()">×</button>
    </div>
  <% } %>
